@startuml
title updatePassword

actor User
participant AuthController
participant AuthService
participant AuthRepository
entity Auth
participant Password
participant ExceptionHandler as "GlobalExceptionHandler\n(@ControllerAdvice)"

User -> AuthController : PATCH /auth/password\n(currentPw, newPw)

AuthController -> AuthService : changePassword(memberId, currentPw, newPw)

AuthService -> AuthRepository : findByMemberId(memberId)
AuthRepository --> AuthService : Auth

AuthService -> Auth : updatePassword(currentPw, newPw)
activate Auth
Auth -> Password : matches(currentPw)
Password -> Auth : true 또는 false

alt 비밀번호 일치
  Auth -> Password : createPassword(newPw)
  Password -> Auth : Password
  deactivate Auth
  AuthService -> AuthRepository : save(Auth)
  AuthService --> AuthController : HTTP 200 OK
  AuthController --> User : HTTP 200 OK

else 비밀번호 불일치
  Auth --> ExceptionHandler : throw InvalidPasswordException
  ExceptionHandler --> User : HTTP 400 Bad Request
end

@enduml